APP_NAME=TronFire
SERVER_PLATFORM=linux-docker
APP_ROOT=/opt/tronfire
STORAGE_ROOT=/opt/tronfire-storage
TRONSOFTOS_STATE_DIR=/opt/tronsoftos/state

# simple: servidor unico. ha: gerenciado pelo TronSoftOS em cluster.
TRONFIRE_DEPLOYMENT_MODE=simple
TRONFIRE_NODE_ROLE=primary
TRONSOFTOS_NODE_NAME=
TRONSOFTOS_CLUSTER_LOCK=/opt/tronsoftos/state/cluster-lock.json
TRONSOFTOS_INTERNAL_TOKEN=

# container: Firebird do stack atual. host: Firebird 2.5.9 instalado no Debian/host.
FIREBIRD_EXEC_MODE=container

TRONFIRE_PANEL_PORT=8081
TRONFIRE_FIREBIRD_PORT=3050
TRONFIRE_LAN_HOST=
PUBLIC_URL=
TRONFIRE_AUTH_DISABLED=true

FIREBIRD_PACKAGE_URL=https://tronsoft.bitrix24.com.br/~qQVae
FIREBIRD_TEMPLATE_URL=https://tronsoft.bitrix24.com.br/~wUw0m
FIREBIRD_PACKAGE_SHA256=
FIREBIRD_TEMPLATE_SHA256=

FIREBIRD_PASSWORD=troque_essa_senha_firebird
POSTGRES_PASSWORD=troque_essa_senha_postgres
SESSION_SECRET=troque_essa_chave_com_32_chars_ou_mais

# Backup em nuvem/rclone e configurado no TronSoftOS.
