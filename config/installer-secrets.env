# Copie para config/installer-secrets.env ou /etc/tronsoftos/installer-secrets.env antes de instalar.
# O arquivo real nao deve ser commitado com token aberto.
TRONSOFTOS_GHCR_REGISTRY=ghcr.io
TRONSOFTOS_GHCR_USER=eduardo-tronsoft
TRONSOFTOS_GHCR_TOKEN=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

# Alternativa: token criptografado.
# O instalador usa TRONSOFTOS_GHCR_TOKEN quando existir; se estiver vazio,
# tenta descriptografar TRONSOFTOS_GHCR_TOKEN_ENC com TRONSOFTOS_GHCR_TOKEN_KEY.
TRONSOFTOS_GHCR_TOKEN_ENC=
TRONSOFTOS_GHCR_TOKEN_KEY=
