#!/usr/bin/env bash
set -euo pipefail

action="${1:-}"

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

fail() {
  local message="$1"
  printf '{"ok":false,"error":"%s"}\n' "$(json_escape "$message")"
  exit 1
}

valid_iface() {
  [[ "$1" =~ ^[A-Za-z0-9_.:-]+$ ]]
}

valid_cidr() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}$ ]]
}

valid_ipv4() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

valid_app_dir() {
  [[ "$1" =~ ^/opt/[A-Za-z0-9._/-]+$ ]]
}

env_escape() {
  printf '%s' "$1" | sed 's/[\/&]/\\&/g'
}

set_env_value() {
  local file="$1"
  local key="$2"
  local value="$3"
  local escaped
  escaped="$(env_escape "$value")"
  [ -f "$file" ] || return 0
  if grep -q "^$key=" "$file"; then
    sed -i "s/^$key=.*/$key=$escaped/" "$file"
  else
    printf '\n%s=%s\n' "$key" "$value" >> "$file"
  fi
}

apply_pairing() {
  local app_dir="$1"
  local source_file="$2"
  local tronsoftos_env="/etc/tronsoftos/tronsoftos.env"
  local tronfire_env="$app_dir/apps/tronfire/.env"
  local troncomanda_env="$app_dir/apps/troncomanda/.env"
  local cluster_secrets="$app_dir/state/cluster-secrets.env"
  local ssh_dir="$app_dir/.ssh"
  local authorized_keys="$ssh_dir/authorized_keys"
  local ssh_key_imported=false

  valid_app_dir "$app_dir" || fail "Diretorio da aplicacao invalido"
  [[ "$source_file" =~ ^/opt/[A-Za-z0-9._/-]+/state/pairing-import-[A-Za-z0-9._-]+\.env$ ]] || fail "Caminho de pareamento invalido"
  [ -f "$source_file" ] || fail "Arquivo de pareamento nao encontrado"

  # shellcheck disable=SC1090
  . "$source_file"

  [ -n "${SESSION_SECRET:-}" ] || fail "SESSION_SECRET ausente no pareamento"
  [ -n "${TRONSOFTOS_INTERNAL_TOKEN:-}" ] || fail "TRONSOFTOS_INTERNAL_TOKEN ausente no pareamento"
  [ -n "${POSTGRES_PASSWORD:-}" ] || fail "POSTGRES_PASSWORD ausente no pareamento"
  [ -n "${FIREBIRD_PASSWORD:-}" ] || fail "FIREBIRD_PASSWORD ausente no pareamento"

  install -m 0600 "$source_file" "$cluster_secrets"

  set_env_value "$tronsoftos_env" "TRONSOFTOS_INTERNAL_TOKEN" "$TRONSOFTOS_INTERNAL_TOKEN"
  if [ -n "${HA_VIP:-}" ]; then
    set_env_value "$tronsoftos_env" "HA_VIP" "$HA_VIP"
  fi
  if [ -n "${HA_VIP_CIDR:-}" ]; then
    set_env_value "$tronsoftos_env" "HA_VIP_CIDR" "$HA_VIP_CIDR"
  fi
  if [ -n "${HA_ROUTER_ID:-}" ]; then
    set_env_value "$tronsoftos_env" "HA_ROUTER_ID" "$HA_ROUTER_ID"
  fi
  if [ -n "${HA_AUTH_PASS:-}" ]; then
    set_env_value "$tronsoftos_env" "HA_AUTH_PASS" "$HA_AUTH_PASS"
  fi
  if [ -n "${HA_PRIMARY_HEALTH_URL:-}" ]; then
    set_env_value "$tronsoftos_env" "HA_PRIMARY_HEALTH_URL" "$HA_PRIMARY_HEALTH_URL"
  fi

  set_env_value "$tronfire_env" "SESSION_SECRET" "$SESSION_SECRET"
  set_env_value "$tronfire_env" "TRONSOFTOS_INTERNAL_TOKEN" "$TRONSOFTOS_INTERNAL_TOKEN"
  set_env_value "$tronfire_env" "FIREBIRD_PASSWORD" "$FIREBIRD_PASSWORD"

  if [ -f "$troncomanda_env" ]; then
    set_env_value "$troncomanda_env" "TRONCOMANDA_FIREBIRD_PASSWORD" "$FIREBIRD_PASSWORD"
  fi

  if [ -n "${TRONSOFTOS_SSH_PUBLIC_KEY:-}" ]; then
    [[ "$TRONSOFTOS_SSH_PUBLIC_KEY" =~ ^(ssh-ed25519|ssh-rsa|ecdsa-sha2-nistp(256|384|521))[[:space:]][A-Za-z0-9+/=]+([[:space:]][A-Za-z0-9_.@:-]+)?$ ]] || fail "Chave publica SSH invalida"
    mkdir -p "$ssh_dir"
    touch "$authorized_keys"
    if ! grep -Fxq "$TRONSOFTOS_SSH_PUBLIC_KEY" "$authorized_keys"; then
      printf '%s\n' "$TRONSOFTOS_SSH_PUBLIC_KEY" >> "$authorized_keys"
    fi
    chown -R tronsoftos:tronsoftos "$ssh_dir" "$app_dir/state" 2>/dev/null || true
    chmod 700 "$ssh_dir"
    chmod 600 "$authorized_keys"
    ssh_key_imported=true
  fi

  printf '{"ok":true,"clusterSecrets":"%s","tronsoftosEnv":"%s","tronfireEnv":"%s","troncomandaEnvUpdated":%s,"sshKeyImported":%s,"authorizedKeys":"%s"}\n' \
    "$(json_escape "$cluster_secrets")" "$(json_escape "$tronsoftos_env")" "$(json_escape "$tronfire_env")" "$([ -f "$troncomanda_env" ] && echo true || echo false)" "$ssh_key_imported" "$(json_escape "$authorized_keys")"
}

sync_ip_envs() {
  local app_dir="$1"
  local iface="$2"
  local address_cidr="$3"
  local gateway="$4"
  local dns="$5"
  local server_ip="${address_cidr%%/*}"
  local service_ip="$server_ip"
  local tronsoftos_env="/etc/tronsoftos/tronsoftos.env"
  local tronfire_env="$app_dir/apps/tronfire/.env"
  local troncomanda_env="$app_dir/apps/troncomanda/.env"

  valid_app_dir "$app_dir" || fail "Diretorio da aplicacao invalido"
  if [ -f "$tronsoftos_env" ] && grep -q '^HA_VIP=.\+' "$tronsoftos_env"; then
    service_ip="$(grep '^HA_VIP=' "$tronsoftos_env" | tail -n1 | cut -d= -f2-)"
  fi

  set_env_value "$tronsoftos_env" "HOST_STATIC_IP_ENABLED" "true"
  set_env_value "$tronsoftos_env" "HOST_STATIC_IP_INTERFACE" "$iface"
  set_env_value "$tronsoftos_env" "HOST_STATIC_IP_ADDRESS_CIDR" "$address_cidr"
  set_env_value "$tronsoftos_env" "HOST_STATIC_IP_GATEWAY" "$gateway"
  set_env_value "$tronsoftos_env" "HOST_STATIC_IP_DNS" "\"$dns\""

  if [ -f "$tronsoftos_env" ] && ! grep -q '^HA_VIP=.\+' "$tronsoftos_env"; then
    set_env_value "$tronsoftos_env" "CLOUDFLARE_TARGET_IP" "$server_ip"
  fi

  set_env_value "$tronfire_env" "TRONFIRE_LAN_HOST" "$service_ip"
  local tronsoftos_port="8080"
  if [ -f "$tronsoftos_env" ] && grep -q '^TRONSOFTOS_PORT=' "$tronsoftos_env"; then
    tronsoftos_port="$(grep '^TRONSOFTOS_PORT=' "$tronsoftos_env" | tail -n1 | cut -d= -f2-)"
  fi
  set_env_value "$tronfire_env" "PUBLIC_URL" "http://$service_ip:$tronsoftos_port/tronfire"

  if [ -f "$troncomanda_env" ]; then
    set_env_value "$troncomanda_env" "TRONCOMANDA_LAN_HOST" "$service_ip"
    local troncomanda_port="8000"
    if grep -q '^TRONCOMANDA_WEB_PORT=' "$troncomanda_env"; then
      troncomanda_port="$(grep '^TRONCOMANDA_WEB_PORT=' "$troncomanda_env" | tail -n1 | cut -d= -f2-)"
    fi
    set_env_value "$troncomanda_env" "TRONCOMANDA_PUBLIC_URL" "http://$service_ip:$troncomanda_port"
  fi
}

sync_service_vip_envs() {
  local app_dir="$1"
  local service_ip="$2"
  local tronsoftos_env="/etc/tronsoftos/tronsoftos.env"
  local tronfire_env="$app_dir/apps/tronfire/.env"
  local troncomanda_env="$app_dir/apps/troncomanda/.env"

  valid_app_dir "$app_dir" || fail "Diretorio da aplicacao invalido"
  valid_ipv4 "$service_ip" || fail "VIP invalido"

  set_env_value "$tronsoftos_env" "CLOUDFLARE_TARGET_IP" "$service_ip"

  set_env_value "$tronfire_env" "TRONFIRE_LAN_HOST" "$service_ip"
  local tronsoftos_port="8080"
  if [ -f "$tronsoftos_env" ] && grep -q '^TRONSOFTOS_PORT=' "$tronsoftos_env"; then
    tronsoftos_port="$(grep '^TRONSOFTOS_PORT=' "$tronsoftos_env" | tail -n1 | cut -d= -f2-)"
  fi
  set_env_value "$tronfire_env" "PUBLIC_URL" "http://$service_ip:$tronsoftos_port/tronfire"

  if [ -f "$troncomanda_env" ]; then
    set_env_value "$troncomanda_env" "TRONCOMANDA_LAN_HOST" "$service_ip"
    local troncomanda_port="8000"
    if grep -q '^TRONCOMANDA_WEB_PORT=' "$troncomanda_env"; then
      troncomanda_port="$(grep '^TRONCOMANDA_WEB_PORT=' "$troncomanda_env" | tail -n1 | cut -d= -f2-)"
    fi
    set_env_value "$troncomanda_env" "TRONCOMANDA_PUBLIC_URL" "http://$service_ip:$troncomanda_port"
  fi
}

apply_vip() {
  local app_dir="${1:-}"
  local iface="${2:-}"
  local vip_cidr="${3:-}"
  local router_id="${4:-51}"
  local auth_pass="${5:-}"
  local node_state="${6:-BACKUP}"
  local priority="${7:-100}"

  valid_app_dir "$app_dir" || fail "Diretorio da aplicacao invalido"
  valid_iface "$iface" || fail "Interface invalida"
  valid_cidr "$vip_cidr" || fail "VIP/CIDR invalido"
  [[ "$router_id" =~ ^[0-9]{1,3}$ ]] || fail "Router ID invalido"
  [ "$router_id" -ge 1 ] && [ "$router_id" -le 255 ] || fail "Router ID deve ficar entre 1 e 255"
  [[ "$priority" =~ ^[0-9]{1,3}$ ]] || fail "Prioridade invalida"
  [ "$priority" -ge 1 ] && [ "$priority" -le 254 ] || fail "Prioridade deve ficar entre 1 e 254"
  [[ "$node_state" =~ ^(MASTER|BACKUP)$ ]] || fail "Papel keepalived invalido"
  [[ "$auth_pass" =~ ^[A-Za-z0-9_.:-]{6,32}$ ]] || fail "Senha VRRP invalida; use 6 a 32 caracteres simples"

  local vip="${vip_cidr%%/*}"
  local tronsoftos_env="/etc/tronsoftos/tronsoftos.env"
  local check_source="$app_dir/infra/keepalived/check-tronsoftos.sh"
  local check_target="/etc/keepalived/check-tronsoftos.sh"
  local conf_target="/etc/keepalived/keepalived.conf"

  [ -f "$check_source" ] || fail "check-tronsoftos.sh nao encontrado"
  mkdir -p /etc/keepalived
  install -m 0755 "$check_source" "$check_target"

  cat > "$conf_target" <<EOF
vrrp_script chk_tronsoftos {
    script "$check_target"
    interval 2
    timeout 2
    fall 3
    rise 2
    weight -50
}

vrrp_instance TRONSOFTOS_VIP {
    state $node_state
    interface $iface
    virtual_router_id $router_id
    priority $priority
    advert_int 1

    authentication {
        auth_type PASS
        auth_pass $auth_pass
    }

    virtual_ipaddress {
        $vip_cidr
    }

    track_script {
        chk_tronsoftos
    }
}
EOF

  set_env_value "$tronsoftos_env" "TRONSOFTOS_KEEPALIVED_ENABLED" "true"
  set_env_value "$tronsoftos_env" "HA_INTERFACE" "$iface"
  set_env_value "$tronsoftos_env" "HA_VIP" "$vip"
  set_env_value "$tronsoftos_env" "HA_VIP_CIDR" "$vip_cidr"
  set_env_value "$tronsoftos_env" "HA_ROUTER_ID" "$router_id"
  set_env_value "$tronsoftos_env" "HA_AUTH_PASS" "$auth_pass"
  set_env_value "$tronsoftos_env" "HA_NODE_ROLE" "$node_state"
  set_env_value "$tronsoftos_env" "HA_PRIORITY" "$priority"

  sync_service_vip_envs "$app_dir" "$vip"

  systemctl enable keepalived.service >/dev/null 2>&1 || true
  systemctl restart keepalived.service

  printf '{"ok":true,"interface":"%s","vip":"%s","vipCidr":"%s","routerId":%s,"nodeState":"%s","priority":%s,"config":"%s"}\n' \
    "$(json_escape "$iface")" "$(json_escape "$vip")" "$(json_escape "$vip_cidr")" "$router_id" "$(json_escape "$node_state")" "$priority" "$(json_escape "$conf_target")"
}

apply_static() {
  local iface="${1:-}"
  local address_cidr="${2:-}"
  local gateway="${3:-}"
  local dns="${4:-}"
  local apply_now="${5:-false}"
  local app_dir="${6:-}"

  valid_iface "$iface" || fail "Interface invalida"
  valid_cidr "$address_cidr" || fail "IP/CIDR invalido"
  valid_ipv4 "$gateway" || fail "Gateway invalido"
  [ -n "$dns" ] || fail "DNS nao informado"
  [ -n "$app_dir" ] && sync_ip_envs "$app_dir" "$iface" "$address_cidr" "$gateway" "$dns"

  if command -v nmcli >/dev/null 2>&1; then
    local connection
    connection="$(nmcli -t -f NAME,DEVICE connection show --active | awk -F: -v dev="$iface" '$2==dev {print $1; exit}')"
    if [ -z "$connection" ]; then
      connection="$(nmcli -t -f NAME,DEVICE connection show | awk -F: -v dev="$iface" '$2==dev {print $1; exit}')"
    fi
    [ -n "$connection" ] || fail "Conexao NetworkManager nao encontrada para $iface"

    nmcli connection modify "$connection" \
      ipv4.addresses "$address_cidr" \
      ipv4.gateway "$gateway" \
      ipv4.dns "$dns" \
      ipv4.method manual \
      connection.autoconnect yes

    if [ "$apply_now" = "true" ]; then
      nmcli connection up "$connection"
    fi

    printf '{"ok":true,"backend":"NetworkManager","interface":"%s","connection":"%s","addressCidr":"%s","applied":%s,"envUpdated":true}\n' \
      "$(json_escape "$iface")" "$(json_escape "$connection")" "$(json_escape "$address_cidr")" "$apply_now"
    return 0
  fi

  if systemctl list-unit-files systemd-networkd.service >/dev/null 2>&1; then
    local network_file="/etc/systemd/network/10-tronsoftos-$iface.network"
    {
      echo "[Match]"
      echo "Name=$iface"
      echo
      echo "[Network]"
      echo "DHCP=no"
      echo "Address=$address_cidr"
      echo "Gateway=$gateway"
      for dns_server in $dns; do
        valid_ipv4 "$dns_server" || fail "DNS invalido: $dns_server"
        echo "DNS=$dns_server"
      done
    } > "$network_file"

    systemctl enable systemd-networkd.service >/dev/null 2>&1 || true
    if [ "$apply_now" = "true" ]; then
      systemctl restart systemd-networkd.service
    fi

    printf '{"ok":true,"backend":"systemd-networkd","interface":"%s","networkFile":"%s","addressCidr":"%s","applied":%s,"envUpdated":true}\n' \
      "$(json_escape "$iface")" "$(json_escape "$network_file")" "$(json_escape "$address_cidr")" "$apply_now"
    return 0
  fi

  fail "Nao encontrei NetworkManager nem systemd-networkd"
}

install_firebird_aliases() {
  local source_file="${1:-}"
  [ -f "$source_file" ] || fail "Arquivo de aliases nao encontrado"
  [[ "$source_file" =~ ^/tmp/tronsoftos-aliases-[A-Za-z0-9._-]+\.conf$ ]] || fail "Caminho de aliases invalido"

  local target="/usr/local/firebird/aliases.conf"
  [ -d /usr/local/firebird ] || fail "/usr/local/firebird nao encontrado"
  install -m 0644 "$source_file" "$target"
  if [ -d /opt/firebird ] && [ ! "$target" -ef /opt/firebird/aliases.conf ]; then
    install -m 0644 "$source_file" /opt/firebird/aliases.conf
  fi

  printf '{"ok":true,"target":"%s"}\n' "$(json_escape "$target")"
}

local_keepalived() {
  local action="${1:-}"
  [[ "$action" =~ ^(start|stop|restart)$ ]] || fail "Acao keepalived invalida"
  systemctl "$action" keepalived.service
  local status="unknown"
  status="$(systemctl is-active keepalived.service 2>/dev/null || true)"
  printf '{"ok":true,"service":"keepalived","action":"%s","status":"%s"}\n' "$(json_escape "$action")" "$(json_escape "$status")"
}

set_node_role() {
  local app_dir="${1:-}"
  local role="${2:-}"
  local tronsoftos_env="/etc/tronsoftos/tronsoftos.env"
  local tronfire_env="$app_dir/apps/tronfire/.env"

  valid_app_dir "$app_dir" || fail "Diretorio da aplicacao invalido"
  [[ "$role" =~ ^(primary|standby|recovery)$ ]] || fail "Papel invalido"

  set_env_value "$tronsoftos_env" "TRONSOFTOS_NODE_ROLE" "$role"
  set_env_value "$tronfire_env" "TRONFIRE_NODE_ROLE" "$role"

  if [ "$role" = "primary" ]; then
    set_env_value "$tronsoftos_env" "HA_NODE_ROLE" "MASTER"
    set_env_value "$tronsoftos_env" "HA_PRIORITY" "150"
  elif [ "$role" = "standby" ]; then
    set_env_value "$tronsoftos_env" "HA_NODE_ROLE" "BACKUP"
    set_env_value "$tronsoftos_env" "HA_PRIORITY" "100"
  fi

  printf '{"ok":true,"role":"%s","tronsoftosEnv":"%s","tronfireEnv":"%s"}\n' \
    "$(json_escape "$role")" "$(json_escape "$tronsoftos_env")" "$(json_escape "$tronfire_env")"
}

host_power() {
  local action="${1:-}"
  [[ "$action" =~ ^(reboot|poweroff)$ ]] || fail "Acao de energia invalida"
  if [ "$action" = "reboot" ]; then
    nohup sh -c 'sleep 2; systemctl reboot' >/dev/null 2>&1 &
  else
    nohup sh -c 'sleep 2; systemctl poweroff' >/dev/null 2>&1 &
  fi
  printf '{"ok":true,"action":"%s","scheduled":true,"delaySeconds":2}\n' "$(json_escape "$action")"
}

case "$action" in
  apply-static)
    shift
    apply_static "$@"
    ;;
  install-firebird-aliases)
    shift
    install_firebird_aliases "$@"
    ;;
  apply-pairing)
    shift
    apply_pairing "$@"
    ;;
  apply-vip)
    shift
    apply_vip "$@"
    ;;
  local-keepalived)
    shift
    local_keepalived "$@"
    ;;
  set-node-role)
    shift
    set_node_role "$@"
    ;;
  host-power)
    shift
    host_power "$@"
    ;;
  *)
    fail "Acao invalida"
    ;;
esac
