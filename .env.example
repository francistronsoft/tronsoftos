# TronSoftOS host service
TRONSOFTOS_USER=tronsoftos
TRONSOFTOS_GROUP=tronsoftos
TRONSOFTOS_APP_DIR=/opt/tronsoftos
TRONSOFTOS_PORT=8080
TRONSOFTOS_HEALTH_URL=http://127.0.0.1:8080/health
TRONSOFTOS_DEPLOYMENT_MODE=simple
TRONSOFTOS_NODE_NAME=servidor-01
TRONSOFTOS_NODE_ROLE=primary
TRONSOFTOS_STATE_DIR=/opt/tronsoftos/state
TRONSOFTOS_LOG_DIR=/opt/tronsoftos/logs
TRONSOFTOS_CLUSTER_LOCK=/opt/tronsoftos/state/cluster-lock.json
TRONSOFTOS_CLUSTER_SECRETS=/opt/tronsoftos/state/cluster-secrets.env
TRONSOFTOS_FRONTEND_DIST=/opt/tronsoftos/frontend/dist

# HA / keepalived
HA_INTERFACE=eth0
HA_VIP=192.168.10.50
HA_ROUTER_ID=51
HA_AUTH_PASS=change-me
HA_NODE_ROLE=MASTER
HA_PRIORITY=150

# Firebird sync
FIREBIRD_SERVICE=firebird
FIREBIRD_DATA_DIR=/var/lib/firebird/data
FIREBIRD_BACKUP_DIR=/opt/tronfire-storage/firebird/backups
FIREBIRD_SYNC_MODE=physical
FIREBIRD_DB_PATTERN=*.fdb
FIREBIRD_RSYNC_TARGET=backup-node:/var/lib/firebird/data
FIREBIRD_RSYNC_SSH_USER=root
FIREBIRD_RSYNC_SSH_PORT=22
HA_SYNC_MODE=physical

# TronFire catalog sync
TRONFIRE_POSTGRES_CONTAINER=tronfire_postgres
TRONFIRE_POSTGRES_DB=tronfire
TRONFIRE_POSTGRES_USER=tronfire
TRONFIRE_CATALOG_EXPORT_DIR=/opt/tronsoftos/state/tronfire-catalog

# Cloud backup via rclone on host
RCLONE_BIN=/usr/bin/rclone
RCLONE_CONFIG=/opt/tronsoftos/config/rclone/rclone.conf
RCLONE_REMOTE=google-drive
RCLONE_BACKUP_PATH=tronsoftos/backups
RCLONE_UPLOAD_ONLY_ROLE=primary
TRONSOFTOS_EXTERNAL_BACKUP_OWNER=true

# Containers managed by host
CONTAINER_RUNTIME=docker
MANAGED_APPS_CONFIG=/opt/tronsoftos/config/managed-apps.json
TRONFIRE_CONTAINER=tronfire
TRONCOMANDA_CONTAINER=troncomanda

# Cloudflare
CLOUDFLARE_API_TOKEN=change-me
CLOUDFLARE_ZONE_ID=change-me
CLOUDFLARE_RECORD_ID=change-me
CLOUDFLARE_RECORD_NAME=tronsoftos.example.com
CLOUDFLARE_RECORD_TYPE=A
CLOUDFLARE_TARGET_IP=192.168.10.50
